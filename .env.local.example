# Copy this file to .env.local and adjust values for your environment.

# Required for production SEO (canonical URLs, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: send real emails via Resend (https://resend.com)
# Without this key, emails are saved to data/email-outbox/ for local testing.
RESEND_API_KEY=
EMAIL_FROM=Keanu Fan <onboarding@resend.dev>

# Session signing secret — set a long random string in production
SESSION_SECRET=change-me-in-production
