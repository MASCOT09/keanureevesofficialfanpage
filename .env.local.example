# Copy this file to .env.local and adjust values for your environment.

# Required for production SEO (canonical URLs, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Session signing secret — set a long random string in production
SESSION_SECRET=change-me-in-production

# Optional: send real emails via Resend (https://resend.com)
# Without this key, emails are saved to data/email-outbox/ for local testing.
RESEND_API_KEY=
EMAIL_FROM=Keanu Fan <onboarding@resend.dev>

# ─── Supabase (production backend) ───────────────────────────────
# When both are set, the app uses Supabase instead of Excel.
# Leave unset for local dev with data/celebrity-site.xlsx.
#
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
